# Required for query rewriting and grounded answer generation
OPENAI_API_KEY=

# Models
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TEMPERATURE=0.0

# Data and persistent Chroma index
DATA_PATH=data/private_school_content.json
LINKS_PATH=data/private_school_links.txt
VECTOR_STORE_PATH=.chroma
CHROMA_COLLECTION=egyptian_private_universities

# Chunking and retrieval
CHUNK_SIZE=1200
CHUNK_OVERLAP=180
TOP_K=5
